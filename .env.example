# ============================================================
# LABO.COS App — Variables d'environnement (TEMPLATE)
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE JAMAIS COMMITTER LE FICHIER .env !

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données PostgreSQL ---
DATABASE_URL=postgres://labocos_user:labocos_pass@localhost:5432/labocos_db

# --- Redis (Celery Broker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@labocos.ma
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=LABO.COS App <noreply@labocos.ma>

# --- Stockage de fichiers (dev = local, prod = S3) ---
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=labocos-media
AWS_S3_REGION_NAME=eu-west-1

# --- Sécurité Production ---
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- django-axes (protection brute-force) ---
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# --- Sentry (monitoring prod) ---
SENTRY_DSN=

# --- Informations Laboratoire ---
LABO_NOM=LABO.COS
LABO_ADRESSE=Adresse du laboratoire
LABO_TEL=+212 XX XX XX XX
LABO_EMAIL=contact@labocos.ma
LABO_SITE=www.labocos.ma
